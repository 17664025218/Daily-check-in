{
  "miniprogramRoot": "./dist",
  "projectname": "每日打卡",
  "description": "每日习惯打卡工具，帮助用户养成好习惯。支持创建打卡任务、记录打卡历史、查看统计数据，让坚持变得更简单。",
  "appid": "touristappid",
  "setting": {
    "urlCheck": true,
    "es6": false,
    "enhance": false,
    "compileHotReLoad": false,
    "postcss": false,
    "minified": false
  },
  "compileType": "miniprogram",
  "packOptions": { "ignore": [{ "type": "folder", "value": "./assets" }] }
}
